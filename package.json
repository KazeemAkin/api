{
  "name": "student-e-commerce-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc -p . --outDir dist_tmp && mv dist dist_old 2>/dev/null || true && mv dist_tmp dist && rm -rf dist_old",
    "build-and-copy": "npm run build && npm run copy-assets",
    "live": "env-cmd -f ./.env node dist/src/server.js",
    "start-live-and-build": "npm run build-and-copy && npm run live",
    "dev": "env-cmd -f ./.env nodemon --exec ts-node --files ./server.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "copy-assets": "copyfiles private.key dist && copyfiles public.key dist && copyfiles -u 1 src/templates/handlebars/emails/**/* dist/src",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.48.3",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.0.1",
    "env-cmd": "^10.1.0",
    "express": "^5.1.0",
    "form-data": "^4.0.5",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "lru-cache": "^11.2.1",
    "mailgun": "^0.5.0",
    "mailgun.js": "^12.7.0",
    "mongodb": "^6.17.0",
    "redis": "^5.8.2",
    "stripe": "^22.1.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.17",
    "@types/lru-cache": "^7.10.10",
    "@types/node": "^22.19.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
